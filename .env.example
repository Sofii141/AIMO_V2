GROQ_API_KEY=pide_la_clave_a_diego_y_ponla_aqui

# Clave de OpenAI para el agente evaluador (G-Eval)
# la de nestor muchachas
OPENAI_API_KEY=sk-tu_clave_openai_aqui

# Credenciales AWS Bedrock (para recomendaciones de riesgo MEDIO — Claude Sonnet 4.5)
AWS_ACCESS_KEY_ID=tu_aws_access_key_aqui
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key_aqui
AWS_REGION=us-east-1
# Dejen esta cosa vacía.
#AWS_SESSION_TOKEN=

# Sobrescribe el modelo Bedrock por defecto
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://aimo-amber.vercel.app,https://*.vercel.app

# Persistencia de sesiones a disco (data/sessions/*.json).
# DESACTIVADA por defecto. En producción NO se debe activar: dejar sin definir
# o en "false". Solo poner "true" en local para análisis académico.
AIMO_PERSIST_SESSIONS=false